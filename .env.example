# Database (Prisma)
# Example: postgresql://postgres:postgres@localhost:5432/serveit?schema=public
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL=
# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=

# NextAuth Configuration
# The base URL of your application
NEXTAUTH_URL=http://localhost:3000
# Secret used to encrypt NextAuth session cookies
NEXTAUTH_SECRET=

# Azure AD (Microsoft Entra ID) SSO Configuration
# If tenant ID is omitted, it will default to the common endpoint.
# Specify your Tenant ID to restrict login to a specific tenant.
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Google Auth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Supabase Configuration
SUPABASE_URL=
# Use the service role key, not the anon key, for backend operations
SUPABASE_SERVICE_ROLE_KEY=
# Name of the Supabase storage bucket (defaults to 'serve-it' if omitted)
SUPABASE_STORAGE_BUCKET=serve-it
